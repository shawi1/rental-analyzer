# rentaliq-data service config (copy to .env)

# Shared secret callers must send as x-api-key (set to a long random string in prod)
API_KEY=dev-local-key

# --- Free data source keys ---
# HUD Fair Market Rents (free, unlimited): https://www.huduser.gov/portal/dataset/fmr-api.html
HUD_API_TOKEN=
# Census ACS data API key (free, instant): https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=
# FRED (free): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# BLS (optional): https://www.bls.gov/developers/
BLS_API_KEY=

# --- MLS RESO Web API (the licensed feed; from his MLS / vendor) ---
# Static-token vendors (MLS Grid, Bridge):
RESO_BASE_URL=
RESO_ACCESS_TOKEN=
# OAuth vendors (Trestle) — alternative to a static token:
RESO_TOKEN_URL=
RESO_CLIENT_ID=
RESO_CLIENT_SECRET=
RESO_DATASET=Property
RESO_VENDOR=generic

# --- behavior ---
ENABLE_SCRAPERS=true
