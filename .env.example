# RentalIQ environment variables (all optional)
#
# You can instead paste keys in the in-app Settings page (stored per-browser).
# Set them here / in your host (Vercel) to share them across devices.

# Anthropic API key — powers AI STR verification, smart paste, report narratives.
# Get one at https://console.anthropic.com/settings/keys  (billing required)
ANTHROPIC_API_KEY=

# Override the Claude model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# RentCast API key — powers budget-based listing search + value/rent estimates.
# Free tier = 50 requests/month at https://app.rentcast.io/app/api
RENTCAST_API_KEY=

# Optional shared password gate. If set, the whole site requires this password
# (HTTP Basic auth, any username). Leave blank for an open site.
SITE_PASSWORD=
